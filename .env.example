# Copy this file to .env for local development and replace every change-me value.
MYSQL_DATABASE=ltss
MYSQL_USER=ltss_app
MYSQL_PASSWORD=change-me-app-password
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_PORT=3306

BACKEND_PORT=8080
FRONTEND_PORT=5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8080/api/v1
JWT_SECRET=change-me-with-at-least-32-random-bytes
JWT_ISSUER=ltss-backend
REFRESH_COOKIE_SECURE=false
FRONTEND_BASE_URL=http://localhost:5173

# Configure an SMTP service and set MAIL_ENABLED=true to deliver account emails.
MAIL_ENABLED=false
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_STARTTLS_ENABLED=false
MAIL_FROM=no-reply@ltss.local
